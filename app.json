{
  "expo": {
    "name": "PulseHealth",
    "slug": "pulsehealth",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "splash": {
      "backgroundColor": "#000000",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pulsehealth.app"
    },
    "android": {
      "package": "com.pulsehealth.app",
      "adaptiveIcon": {
        "backgroundColor": "#000000"
      }
    },
    "plugins": [],
    "experiments": {
      "baseUrl": "/pulsehealth"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    }
  }
}
